{
  "name": "404game",
  "version": "0.1.0",
  "description": "Turn boring 404 pages into playable mini-games. Drop-in JS library with snake, flappy, breakout, and dino runner. Zero dependencies.",
  "type": "module",
  "main": "./dist/404game.umd.cjs",
  "module": "./dist/404game.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/404game.js",
      "require": "./dist/404game.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "404",
    "game",
    "mini-game",
    "snake",
    "flappy",
    "breakout",
    "dino",
    "embed",
    "library",
    "easter-egg",
    "canvas",
    "browser-game",
    "zero-dependencies",
    "typescript"
  ],
  "author": "x1n-Q",
  "license": "MIT",
  "homepage": "https://x1n-q.github.io/404game/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x1n-Q/404game.git"
  },
  "bugs": {
    "url": "https://github.com/x1n-Q/404game/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=14"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
